  "item": [
    {
      "name": "Products API - Data Driven Tests",
      "item": [
        {
          "name": "Get Products with Pagination",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test response status code",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test response time",
                  "pm.test(\"Response time is less than 10000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(10000);",
                  "});",
                  "",
                  "// Test response structure",
                  "pm.test(\"Response has correct structure\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    if (pm.response.code === 200) {",
                  "        pm.expect(responseJson).to.have.property('data');",
                  "        pm.expect(responseJson).to.have.property('current_page');",
                  "        pm.expect(responseJson.data).to.be.an('array');",
                  "        if (responseJson.data.length > 0) {",
                  "            pm.expect(responseJson.data[0]).to.have.property('id');",
                  "            pm.expect(responseJson.data[0]).to.have.property('name');",
                  "        }",
                  "    }",
                  "});",
                  "",
                  "// Test pagination",
                  "pm.test(\"Pagination works correctly\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.current_page).to.be.a('number');",
                  "    pm.expect(responseJson.data).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/products?page={{page}}&limit={{limit}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}",
                  "description": "Page number for pagination"
                },
                {
                  "key": "limit",
                  "value": "{{limit}}",
                  "description": "Number of items per page"
                }
              ]
            },
            "description": "Get products with pagination using data-driven approach"
          },
          "response": []
        },
