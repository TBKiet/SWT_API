  "item": [
    {
      "name": "Users API - Data Driven Tests",
      "item": [
        {
          "name": "Get Users with Pagination",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response time is less than 10000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(10000);",
                  "});",
                  "pm.test(\"Response has correct structure\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('data');",
                  "    pm.expect(responseJson.data).to.be.an('array');",
                  "    if (responseJson.data.length > 0) {",
                  "        pm.expect(responseJson.data[0]).to.have.property('id');",
                  "        pm.expect(responseJson.data[0]).to.have.property('email');",
                  "    }",
                  "});",
                  "pm.test(\"Pagination works correctly\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.current_page).to.be.a('number');",
                  "    pm.expect(responseJson.data).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users?page={{page}}&limit={{limit}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}",
                  "description": "Page number for pagination"
                },
                {
                  "key": "limit",
                  "value": "{{limit}}",
                  "description": "Number of items per page"
                }
              ]
            },
            "description": "Get users with pagination using data-driven approach"
          },
          "response": []
        },
